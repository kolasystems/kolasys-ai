# Kolasys AI — Example environment variables
# Copy this file to `.env` and fill in the real values. The app expects every
# variable marked "Required" below; optional variables degrade gracefully.

# ───── Required — core ──────────────────────────────────────────────────────

# Neon PostgreSQL connection string (include ?sslmode=require)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Public URL of the deployed app. Used for callbacks and tRPC client.
NEXT_PUBLIC_APP_URL=https://app.kolasys.ai

# ───── Required — Clerk (auth + organisations) ──────────────────────────────

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ───── Required — Redis (BullMQ workers) ────────────────────────────────────

# Upstash redis URL. Format: rediss://default:<password>@<host>:<port>
REDIS_URL=

# ───── Required — AI ────────────────────────────────────────────────────────

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ───── Required — S3 (audio storage) ────────────────────────────────────────

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=kolasys-ai-recordings

# ───── Required features ────────────────────────────────────────────────────

RECALLAI_API_KEY=
RECALLAI_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=notes@kolasys.ai

# ───── Web Push (VAPID) ─────────────────────────────────────────────────────
# Generate via: npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: or https:// URL identifying the sender.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hi@kolasys.ai

# ───── Google OAuth (Calendar sync) ─────────────────────────────────────────
# Create an OAuth 2.0 client at console.cloud.google.com. Authorised redirect
# URI must match: https://app.kolasys.ai/api/auth/google/callback (or the
# equivalent ngrok URL in dev). GOOGLE_REDIRECT_URI overrides the default if set.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.kolasys.ai/api/auth/google/callback

# ───── Optional — Deepgram (speaker diarization) ────────────────────────────

DEEPGRAM_API_KEY=

# ───── Optional — Sentry (error tracking) ───────────────────────────────────

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ───── Optional — PostHog (analytics) ───────────────────────────────────────

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
