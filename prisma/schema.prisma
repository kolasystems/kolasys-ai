// Kolasys AI — Prisma Schema
// Prisma v7 · PostgreSQL

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum RecordingSource {
  UPLOAD
  BROWSER
  MEETING_BOT
  DESKTOP
  IMPORT
}

enum RecordingStatus {
  PENDING
  PROCESSING
  TRANSCRIBING
  SUMMARIZING
  READY
  FAILED
}

enum MeetingPlatform {
  ZOOM
  GOOGLE_MEET
  MICROSOFT_TEAMS
  WEBEX
  OTHER
}

enum JobType {
  TRANSCRIPTION
  SUMMARIZATION
  ACTION_ITEMS
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum KnowledgeEntityType {
  PERSON
  TOPIC
  PROJECT
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Organization {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  plan             Plan      @default(FREE)
  clerkOrgId       String?   @unique
  // Integrations
  slackWebhookUrl  String?
  notionApiKey     String?
  notionDatabaseId String?
  // Audio retention — when true, the transcription worker deletes the S3
  // audio file after transcription completes. Default is false (keep audio)
  // so users can re-transcribe and play back recordings from the detail view.
  deleteAudioAfterTranscription Boolean @default(false)
  // Post-meeting email — when true (default), the summarization worker emails
  // the recording owner once notes are ready. Users can opt out per-org.
  postMeetingEmail              Boolean @default(true)
  // Daily digest — when true (default), the 8 AM cron sends a morning summary
  // of yesterday's meetings + open action items to the org's members.
  dailyDigest                   Boolean @default(true)
  // Default language passed to Whisper for new uploads. Uses ISO 639-1 codes
  // (e.g. "en", "es", "fr"). Use "auto" to let Whisper detect the language.
  defaultTranscriptionLanguage  String  @default("en")
  // Recording capture — per-org name that the Recall.ai bot joins meetings
  // under. Defaults to the product name; orgs can brand it (e.g. "Acme AI").
  botDisplayName                String  @default("Kolasys AI")
  // Single Sign-On (Enterprise) — SAML 2.0 config. When ssoEnabled is true
  // and ssoDomain is set, sign-in attempts from that email domain are
  // redirected through the customer's IdP (metadata at samlMetadataUrl).
  ssoEnabled                    Boolean @default(false)
  ssoDomain                     String?
  samlMetadataUrl               String?
  // Trial tracking — managed via the /admin portal. trialStartedAt records
  // when the trial began, trialEndsAt is the cutoff. Both null = no trial.
  trialStartedAt                DateTime?
  trialEndsAt                   DateTime?
  // Free-form admin notes (only visible in /admin, never to the org itself).
  notes                         String?
  // Usage cap. 0 = unlimited. Compared against the count of recordings the
  // org has created in the current calendar month.
  maxRecordingsPerMonth         Int       @default(0)
  // Stripe linkage — set manually from /admin until the real billing flow
  // ships. customerId is the source of truth; subscriptionId is informational.
  stripeCustomerId              String?
  stripeSubscriptionId          String?
  // Hard suspension toggle. The visual flag is enforced in the admin UI;
  // tRPC enforcement is intentionally separate (not in scope here).
  suspended                     Boolean   @default(false)
  suspendedReason               String?
  // Calendar bot — when true (default), the calendar-bot Railway worker
  // auto-deploys a Recall.ai bot to upcoming calendar meetings 4-6 minutes
  // before they start. Org members must have a calendar (Google/Microsoft)
  // refresh token saved for the worker to discover their events.
  autoRecordMeetings            Boolean   @default(true)
  // Last time the calendar-bot worker successfully completed a poll for
  // this org. Surfaced in /admin for at-a-glance worker visibility.
  lastCalendarBotRun            DateTime?
  // AI context — used in Claude prompts to improve transcription/summary quality.
  internalJargon                String?
  companyDescription            String?
  // Auto-delete transcripts after N days (null = keep forever).
  autoDeleteTranscriptsDays     Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  members          OrgMember[]
  recordings       Recording[]
  apiKeys          ApiKey[]
  templates        NoteTemplate[]
  knowledgeEntities KnowledgeEntity[]
  soundbites       Soundbite[]
  meetingSeries    MeetingSeries[]
}

model OrgMember {
  id                 String     @id @default(cuid())
  orgId              String
  userId             String     // Clerk user ID
  role               MemberRole @default(MEMBER)
  googleRefreshToken String?    // OAuth refresh token for Google Calendar
  microsoftRefreshToken String? // OAuth refresh token for Microsoft Outlook Calendar
  // Expo push token registered by the mobile app on launch. Per-member so
  // each user's iPhone (and mirrored Apple Watch) gets its own ping when
  // their own recordings finish summarization.
  expoPushToken      String?
  botDisplayName       String?    // overrides Organization.botDisplayName for this member's bot
  botAvatarS3Key       String?    // S3 key of rendered 1280×720 camera JPEG
  emailSummaryOnReady  Boolean    @default(true)   // per-user toggle — send summary email when recording is ready
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  org           Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  webPushSubs   WebPushSubscription[]

  @@unique([orgId, userId])
  @@index([userId])
}

model Recording {
  id          String           @id @default(cuid())
  orgId       String
  userId      String           // Clerk user ID of creator
  title       String
  description String?
  source      RecordingSource
  status      RecordingStatus  @default(PENDING)
  platform    MeetingPlatform?
  meetingUrl  String?
  botId       String?          // Recall.ai bot ID
  s3Key       String?
  s3Bucket    String?
  duration    Int?             // seconds
  fileSize    Int?             // bytes
  mimeType    String?
  scheduledAt DateTime?
  startedAt   DateTime?
  endedAt     DateTime?
  // Public sharing — when isPublic=true, /share/{publicSlug} renders the
  // notes + transcript without auth. publicSlug is null until the owner
  // hits "Share" the first time; cleared on Make Private.
  isPublic         Boolean   @default(false)
  publicSlug       String?   @unique
  // Per-share permission map: { transcript, summary, actionItems } booleans.
  // null = all-on (the historical default before this column was added).
  sharePermissions Json?
  // Expiry — the public page renders a "link expired" view past this point.
  // null = never expires.
  shareExpiresAt   DateTime?
  // Free-form personal notes typed by the user (desktop/web). Distinct from
  // the AI-generated `notes` relation below. null until first edited.
  personalNotes    String?
  importPlatform   String?
  importedAt       DateTime?
  summaryEmailSentAt DateTime?  // idempotency guard — set when post-meeting summary email is sent
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  org          Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  transcript   Transcript?
  notes        Note[]
  jobs         ProcessingJob[]
  speakerLabels SpeakerLabel[]
  knowledgeLinks KnowledgeEntityRecording[]
  soundbites   Soundbite[]
  shareInvites SharedInvite[]
  seriesMemberships RecordingSeriesMembership[]

  @@index([orgId, status])
  @@index([orgId, createdAt(sort: Desc)])
}

// ── Meeting Series ─────────────────────────────────────────────────────────
// Auto-detected groupings of related recordings (e.g. recurring standups,
// project syncs). Created by the summarization worker's title-similarity
// pass; renameable + curatable from /dashboard/series.

model MeetingSeries {
  id           String    @id @default(cuid())
  orgId        String
  name         String
  description  String?
  autoDetected Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  org          Organization                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  recordings   RecordingSeriesMembership[]

  @@index([orgId])
}

model RecordingSeriesMembership {
  id          String   @id @default(cuid())
  seriesId    String
  recordingId String
  createdAt   DateTime @default(now())

  series      MeetingSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  recording   Recording     @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  @@unique([seriesId, recordingId])
  @@index([recordingId])
}

model Transcript {
  id          String   @id @default(cuid())
  recordingId String   @unique
  language    String   @default("en")
  text        String
  confidence  Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recording Recording           @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  segments  TranscriptSegment[]
}

model TranscriptSegment {
  id           String   @id @default(cuid())
  transcriptId String
  speaker      String?
  text         String
  startTime    Float    // seconds
  endTime      Float    // seconds
  confidence   Float?
  // Word-level timestamps from Whisper — JSON-encoded array of
  // { word: string; start: number; end: number }. Null on segments that were
  // transcribed before word granularity was added. Kept as JSON text rather
  // than a separate Word table to avoid a multi-hundred-row join per segment.
  wordsJson    String?
  createdAt    DateTime @default(now())

  transcript Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)

  @@index([transcriptId, startTime])
}

// Speaker display name mappings — users can rename "SPEAKER_0" to "John Smith"
model SpeakerLabel {
  id          String   @id @default(cuid())
  recordingId String
  speakerId   String   // "SPEAKER_0", "SPEAKER_1", etc.
  displayName String   // user-editable label
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recording Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  @@unique([recordingId, speakerId])
  @@index([recordingId])
}

model Note {
  id          String   @id @default(cuid())
  recordingId String
  orgId       String
  userId      String   // Clerk user ID of creator
  title       String
  summary     String?
  templateId  String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recording   Recording     @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  template    NoteTemplate? @relation(fields: [templateId], references: [id])
  sections    NoteSection[]
  actionItems ActionItem[]
  comments    NoteComment[]

  @@index([recordingId])
  @@index([orgId, createdAt(sort: Desc)])
}

model NoteSection {
  id        String   @id @default(cuid())
  noteId    String
  title     String
  content   String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, order])
}

model ActionItem {
  id          String           @id @default(cuid())
  noteId      String
  orgId       String
  title       String
  description String?
  assignee    String?          // Clerk user ID
  dueDate     DateTime?
  status      ActionItemStatus @default(OPEN)
  priority    Priority         @default(MEDIUM)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([orgId, status])
}

model NoteComment {
  id        String   @id @default(cuid())
  noteId    String
  userId    String   // Clerk user ID
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
}

model NoteTemplate {
  id          String   @id @default(cuid())
  orgId       String?  // null = global (built-in) template
  name        String
  description String?  // short user-facing description
  prompt      String?  // high-level system prompt prepended to section instructions
  category    String?  // e.g. "Meeting", "Medical", "Sales"
  structure   Json     // array of { title, prompt } section definitions
  // Auto-apply rules: Array<{ field: 'title'|'attendees', pattern: string
  // (regex source), priority: number }>. Summarization worker picks the
  // highest-priority template whose pattern matches the meeting title /
  // attendee list. Null = template never auto-applies.
  autoApplyRules Json?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org   Organization? @relation(fields: [orgId], references: [id])
  notes Note[]

  @@index([orgId])
}

model ProcessingJob {
  id          String    @id @default(cuid())
  recordingId String
  type        JobType
  status      JobStatus @default(QUEUED)
  payload     Json?
  result      Json?
  error       String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  recording Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  @@index([recordingId])
  @@index([status, type])
}

model ApiKey {
  id         String       @id @default(cuid())
  orgId      String
  name       String
  // SHA-256 hash of the raw key. The raw key is shown to the user exactly
  // once at creation time and never stored.
  keyHash    String       @unique
  // Last 4 chars of the raw key, displayed in the UI as `kol_…XXXX` so
  // users can identify which key they're looking at without revealing it.
  keyPreview String       @default("")
  lastUsedAt DateTime?
  // When non-null, the key has been revoked and authentication must reject
  // it. Soft-delete instead of hard-delete so audit trails survive.
  revokedAt  DateTime?
  expiresAt  DateTime?
  createdAt  DateTime     @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

// pgvector-backed embeddings table. Managed at runtime by `src/lib/db-vector.ts`
// via raw Neon SQL — declared here so `prisma db push` doesn't drop it.
// The `embedding` column uses the `vector(1536)` type; Prisma exposes it via
// the Unsupported escape hatch and does not read/write it directly.
model TranscriptEmbedding {
  id          String                          @id @default(dbgenerated("gen_random_uuid()::text"))
  orgId       String
  recordingId String
  chunkIndex  Int
  chunkText   String
  embedding   Unsupported("vector(1536)")?
  startTime   Float?
  endTime     Float?
  createdAt   DateTime?                       @default(now()) @db.Timestamptz(6)

  @@index([orgId], map: "idx_te_org")
  @@index([recordingId], map: "idx_te_recording")
}

// ─── Personal Knowledge Graph ─────────────────────────────────────────────
//
// KnowledgeEntity: a normalized person / topic / project extracted by Claude
// from meeting transcripts. `name` is stored lowercase-trimmed so repeat
// extractions collapse into a single row via the (orgId, type, name) unique.
// `aliases` keeps the original cased variants we've seen.
// KnowledgeEntityRecording: junction row linking an entity to every recording
// it was mentioned in, with per-recording mention count for weighting.

model KnowledgeEntity {
  id        String              @id @default(cuid())
  orgId     String
  type      KnowledgeEntityType
  name      String              // normalized lowercase
  aliases   String[]            // alternate casings / variants
  mentions  Int                 @default(1)
  lastSeen  DateTime            @default(now())
  firstSeen DateTime            @default(now())
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  org            Organization               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  recordingLinks KnowledgeEntityRecording[]

  @@unique([orgId, type, name])
  @@index([orgId, type])
}

model KnowledgeEntityRecording {
  id          String   @id @default(cuid())
  entityId    String
  recordingId String
  mentions    Int      @default(1)
  createdAt   DateTime @default(now())

  entity    KnowledgeEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  recording Recording       @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  @@unique([entityId, recordingId])
  @@index([recordingId])
}

// ── Admin portal access control ──────────────────────────────────────────────
// Users in this table can sign into /admin (gated by Clerk first, then by
// their email's presence here). Role determines what they can do once in.

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
}

model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  role      AdminRole @default(ADMIN)
  // Email of the SUPER_ADMIN who added this row, or "system" for the
  // bootstrap seed.
  addedBy   String?
  createdAt DateTime  @default(now())
}

// Append-only audit trail of every mutation performed via /admin.
// Written to from inside each server action; never updated or deleted.
model AdminAuditLog {
  id          String   @id @default(cuid())
  // Email of the admin who performed the action — captured at write time
  // so the row stays meaningful even if the AdminUser is later removed.
  adminEmail  String
  // Short identifier for the action (e.g. "cyclePlan", "suspendOrg").
  action      String
  targetOrgId String?
  targetEmail String?
  // Free-form summary of what changed. Avoid dumping sensitive payloads
  // (emailed bodies, full note text) — store length/counts instead.
  details     String?
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([targetOrgId])
}

// ── Soundbites — short clip highlights of a recording ───────────────────────
// Just metadata + transcript text; the actual audio is a virtual range
// rendered against the parent Recording's audio file.
model Soundbite {
  id           String   @id @default(cuid())
  recordingId  String
  orgId        String
  title        String
  startSeconds Float
  endSeconds   Float
  transcript   String?
  createdAt    DateTime @default(now())

  recording Recording    @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([recordingId, startSeconds])
  @@index([orgId, createdAt(sort: Desc)])
}

// ── Recording share invites ────────────────────────────────────────────────
// Users the owner has explicitly invited to a public-share recording.
// Stored for an audit trail; access enforcement (e.g. requiring a Clerk
// session whose email matches an invite) is a follow-up — for now the
// /share/{slug} page is open to anyone with the link.
model SharedInvite {
  id          String   @id @default(cuid())
  recordingId String
  email       String
  invitedBy   String   // Clerk userId of the inviter
  createdAt   DateTime @default(now())

  recording Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  @@unique([recordingId, email])
  @@index([recordingId])
}

// ── Web Push subscriptions — one per (member, browser) ─────────────────────
// Endpoint is the unique URL Push Service hands the browser; p256dh + auth
// are the encryption keys we sign payloads against.
model WebPushSubscription {
  id          String   @id @default(cuid())
  orgMemberId String
  endpoint    String   @unique
  p256dh      String
  auth        String
  createdAt   DateTime @default(now())

  orgMember OrgMember @relation(fields: [orgMemberId], references: [id], onDelete: Cascade)

  @@index([orgMemberId])
}
